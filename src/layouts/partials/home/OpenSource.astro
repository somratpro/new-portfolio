---
import SectionLabel from "@/components/SectionLabel.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { FaGithub } from "react-icons/fa6";

const { opensource } = Astro.props;

interface Stat {
  value: number;
  suffix?: string;
  label: string;
}
---

<section id="opensource" class="section scroll-mt-24 pt-0">
  <div class="container">
    <div
      class="reveal rounded-3xl bg-dark p-10 md:p-14 lg:p-16 dark:border dark:border-darkmode-border dark:bg-darkmode-light"
      data-reveal
    >
      <div class="grid gap-x-10 gap-y-10 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-5">
          <SectionLabel
            index="05"
            text={opensource.subtitle}
            invert
            className="mb-4"
          />
          <h2
            class="mb-5 text-h3 text-light md:text-h2 dark:text-darkmode-text-dark [&_em]:text-darkmode-accent"
            set:html={markdownify(opensource.title)}
          />
          <p
            class="mb-8 text-light/70 dark:text-darkmode-text"
            set:html={markdownify(opensource.content)}
          />
          {
            opensource.button.enable && (
              <a
                class="btn btn-invert"
                href={opensource.button.link}
                target="_blank"
                rel="noopener"
              >
                <FaGithub className="mr-2 inline-block h-4 w-4" />
                {opensource.button.label}
              </a>
            )
          }
        </div>
        <div class="lg:col-span-7">
          <div class="grid grid-cols-2 gap-x-8 gap-y-10">
            {
              opensource.stats.map((stat: Stat) => (
                <div>
                  <span class="font-secondary mb-2 block text-[clamp(2.6rem,4.5vw,3.9rem)] leading-none text-darkmode-accent">
                    <span data-count={stat.value}>{stat.value}</span>
                    {stat.suffix}
                  </span>
                  <span class="block text-sm text-light/60 dark:text-darkmode-text-light">
                    {stat.label}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
