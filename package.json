{
  "name": "astroplate",
  "version": "6.2.1",
  "description": "Astro and Tailwindcss boilerplate",
  "author": "zeon.studio",
  "license": "MIT",
  "packageManager": "pnpm@11.8.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node scripts/themeGenerator.js --watch\" \"astro dev\"",
    "build": "node scripts/themeGenerator.js && astro build && node scripts/llmsGenerator.js",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier -w ./src",
    "generate-llms": "node scripts/llmsGenerator.js"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/react": "6.0.0",
    "@astrojs/sitemap": "3.7.3",
    "@digi4care/astro-google-tagmanager": "^2.0.0",
    "astro": "7.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "sharp": "^0.35.2",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "glob": "^13.0.6",
    "node-html-parser": "^8.0.3",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwind-bootstrap-grid": "^7.0.0",
    "tailwindcss": "^4.3.1",
    "turndown": "^7.2.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "typescript": "$typescript",
    "astro": "$astro"
  }
}
